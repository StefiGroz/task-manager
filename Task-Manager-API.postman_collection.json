{
  "info": {
    "_postman_id": "task-manager-collection",
    "name": "Task Manager API",
    "description": "Complete Task Manager REST API collection for testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "task-manager"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "api_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "task_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "description": "Server health and status endpoints",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check server and database status"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "description": "Task management endpoints",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_url}}/tasks",
              "host": ["{{api_url}}"],
              "path": ["tasks"]
            },
            "description": "Retrieve all tasks"
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_url}}/tasks/{{task_id}}",
              "host": ["{{api_url}}"],
              "path": ["tasks", "{{task_id}}"]
            },
            "description": "Retrieve a specific task by ID"
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread, and vegetables\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/tasks",
              "host": ["{{api_url}}"],
              "path": ["tasks"]
            },
            "description": "Create a new task"
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/tasks/{{task_id}}",
              "host": ["{{api_url}}"],
              "path": ["tasks", "{{task_id}}"]
            },
            "description": "Update task status (TODO, IN_PROGRESS, DONE)"
          }
        },
        {
          "name": "Update Task Title",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated task title\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/tasks/{{task_id}}",
              "host": ["{{api_url}}"],
              "path": ["tasks", "{{task_id}}"]
            },
            "description": "Update task title and/or description"
          }
        },
        {
          "name": "Update Task (All Fields)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Completely updated title\",\n  \"description\": \"Completely updated description\",\n  \"status\": \"DONE\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/tasks/{{task_id}}",
              "host": ["{{api_url}}"],
              "path": ["tasks", "{{task_id}}"]
            },
            "description": "Update all task fields"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{api_url}}/tasks/{{task_id}}",
              "host": ["{{api_url}}"],
              "path": ["tasks", "{{task_id}}"]
            },
            "description": "Delete a task"
          }
        }
      ]
    },
    {
      "name": "Workflow Examples",
      "description": "Example workflows combining multiple requests",
      "item": [
        {
          "name": "Complete Workflow (Create, Update, Delete)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_url}}/tasks",
              "host": ["{{api_url}}"],
              "path": ["tasks"]
            },
            "description": "Example workflow:\n1. Create a new task\n2. Update its status\n3. Delete the task\n\nManually perform these steps:\n- First, run 'Create Task' request\n- Copy the ID from response\n- Set task_id variable to that ID\n- Run 'Update Task Status'\n- Run 'Delete Task'"
          }
        }
      ]
    }
  ]
}
